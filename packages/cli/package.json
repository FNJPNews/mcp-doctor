{
  "name": "@fnjp/mcp-doctor",
  "version": "0.3.0-alpha",
  "description": "Command-line interface for MCP Doctor.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/FNJPNews/mcp-doctor.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/FNJPNews/mcp-doctor#readme",
  "bugs": {
    "url": "https://github.com/FNJPNews/mcp-doctor/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mcp-doctor": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "corepack pnpm --filter @mcp-doctor/core build && node ../../scripts/clean.mjs dist && tsc -p tsconfig.build.json && node ../../scripts/bundle-cli-core.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment node",
    "lint": "eslint src test --ext .ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mcp-doctor/core": "workspace:*",
    "vitest": "^2.0.5"
  }
}
