{
  "name": "@mcp-doctor/core",
  "version": "0.3.0-alpha",
  "description": "Core scanning, parsing, redaction, auditing, and test logic for MCP Doctor.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/FNJPNews/mcp-doctor.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/FNJPNews/mcp-doctor#readme",
  "bugs": {
    "url": "https://github.com/FNJPNews/mcp-doctor/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist-cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist-cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean.mjs dist dist-cjs && tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-package-type.mjs dist-cjs commonjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment node",
    "lint": "eslint src test --ext .ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.0.5"
  }
}
