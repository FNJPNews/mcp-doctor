{
  "name": "mcp-doctor",
  "version": "0.3.0-alpha",
  "private": true,
  "description": "Local-first CLI and VS Code extension for scanning, testing, and auditing MCP server configurations.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "node packages/cli/dist/cli.js",
    "lint": "eslint . --ext .ts,.js,.cjs",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm --filter @mcp-doctor/core build && corepack pnpm -r test",
    "build": "corepack pnpm -r build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
